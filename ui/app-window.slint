import { VerticalBox } from "std-widgets.slint";

export component HistoryWindow inherits Window {
    title: "Clip Keeper";
    width: 640px;
    height: 420px;
    in property <[string]> history-items;

    VerticalBox {
        spacing: 8px;
        padding: 12px;

        Text {
            text: "Clipboard History";
            font-size: 22px;
            font-weight: 700;
        }

        Rectangle {
            border-width: 1px;
            border-color: #6a6a6a;
            border-radius: 6px;
            vertical-stretch: 1;
            clip: true;

            VerticalBox {
                spacing: 4px;
                padding: 8px;

                for item[index] in root.history-items: Text {
                    text: "\{index + 1}. \{item}";
                    wrap: word-wrap;
                }
            }
        }
    }
}

export component SettingsWindow inherits Window {
    title: "Clip Keeper Settings";
    width: 420px;
    height: 240px;

    VerticalBox {
        spacing: 8px;
        padding: 12px;

        Text {
            text: "Settings";
            font-size: 22px;
            font-weight: 700;
        }

        Text {
            wrap: word-wrap;
            text: "Base implementation. Tray menu and hotkeys are wired from Rust side. Add actual settings controls here.";
        }
    }
}
