import { CheckBox, LineEdit, VerticalBox } from "std-widgets.slint";

export component HistoryWindow inherits Window {
    title: "クリップキーパー";
    width: 640px;
    height: 420px;
    in property <[string]> history-items;
    // キーボードで現在フォーカスされている行のインデックス（-1 = 未選択）
    in-out property <int> selected-index: 0;
    callback request-select-history-item(int);

    // ウィンドウ表示時にキーボードフォーカスをリストスコープへ転送する
    forward-focus: key-handler;

    key-handler := FocusScope {
        key-pressed(event) => {
            if event.text == Key.UpArrow {
                if root.selected-index > 0 {
                    root.selected-index -= 1;
                }
                return accept;
            }
            if event.text == Key.DownArrow {
                if root.selected-index < root.history-items.length - 1 {
                    root.selected-index += 1;
                }
                return accept;
            }
            if event.text == Key.Return {
                if root.history-items.length > 0 {
                    root.request-select-history-item(root.selected-index);
                }
                return accept;
            }
            reject
        }

        VerticalBox {
            spacing: 8px;
            padding: 12px;

            Text {
                text: "クリップボード履歴";
                font-size: 22px;
                font-weight: 700;
            }

            Rectangle {
                border-width: 1px;
                border-color: #6a6a6a;
                border-radius: 6px;
                vertical-stretch: 1;
                clip: true;

                VerticalBox {
                    spacing: 4px;
                    padding: 8px;

                    for item[index] in root.history-items: Rectangle {
                        min-height: 30px;
                        border-radius: 4px;
                        // 優先度: 押下 > キーボード選択 > ホバー > 通常
                        background: touch.pressed        ? #b3cfff
                                  : index == root.selected-index ? #cfe1ff
                                  : touch.has-hover     ? #e0e0e0
                                  : #f4f4f4;

                        Text {
                            x: 8px;
                            y: 6px;
                            width: parent.width - 16px;
                            text: "\{index + 1}. \{item}";
                            color: #111111;
                            wrap: word-wrap;
                        }

                        touch := TouchArea {
                            clicked => {
                                root.selected-index = index;
                                root.request-select-history-item(index);
                            }
                        }
                    }
                }
            }
        }
    }
}

export component SettingsWindow inherits Window {
    title: "クリップキーパー設定";
    width: 460px;
    height: 360px;

    in-out property <bool> hotkey-ctrl-double-tap-enabled: true;
    in-out property <bool> hotkey-shift-double-tap-enabled: true;
    in-out property <bool> hotkey-combo-ctrl-required: true;
    in-out property <bool> hotkey-combo-shift-required: true;
    in-out property <string> hotkey-combo-key: "H";

    callback request-set-hotkey-ctrl-double-tap-enabled(bool);
    callback request-set-hotkey-shift-double-tap-enabled(bool);
    callback request-set-hotkey-combo-ctrl-required(bool);
    callback request-set-hotkey-combo-shift-required(bool);
    callback request-set-hotkey-combo-key(string);

    VerticalBox {
        spacing: 8px;
        padding: 12px;

        Text {
            text: "設定";
            font-size: 22px;
            font-weight: 700;
        }

        Text {
            text: "ホットキー設定";
            font-size: 16px;
            font-weight: 600;
        }

        CheckBox {
            text: "Ctrl 2回押しを有効化";
            checked <=> root.hotkey-ctrl-double-tap-enabled;
            toggled => {
                root.request-set-hotkey-ctrl-double-tap-enabled(self.checked);
            }
        }

        CheckBox {
            text: "Shift 2回押しを有効化";
            checked <=> root.hotkey-shift-double-tap-enabled;
            toggled => {
                root.request-set-hotkey-shift-double-tap-enabled(self.checked);
            }
        }

        CheckBox {
            text: "組み合わせホットキーにCtrlを必須にする";
            checked <=> root.hotkey-combo-ctrl-required;
            toggled => {
                root.request-set-hotkey-combo-ctrl-required(self.checked);
            }
        }

        CheckBox {
            text: "組み合わせホットキーにShiftを必須にする";
            checked <=> root.hotkey-combo-shift-required;
            toggled => {
                root.request-set-hotkey-combo-shift-required(self.checked);
            }
        }

        Text {
            text: "組み合わせキー（A-Z / 0-9、初期値 H）";
        }

        LineEdit {
            text <=> root.hotkey-combo-key;
            edited(new-value) => {
                root.request-set-hotkey-combo-key(new-value);
            }
        }

        Text {
            wrap: word-wrap;
            text: "変更はすぐに settings.json に保存されます。";
        }
    }
}
