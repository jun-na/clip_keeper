import { Button, CheckBox, ComboBox, LineEdit, ScrollView, TabWidget, TextEdit, VerticalBox } from "std-widgets.slint";

export struct SavedEntry {
    title: string,
    content: string,
}

export component HistoryWindow inherits Window {
    title: "クリップキーパー";
    min-width: 400px;
    min-height: 300px;
    preferred-width: 640px;
    preferred-height: 420px;

    in property <[string]> history-items;
    in property <[SavedEntry]> saved-items;
    in property <[string]> group-names;
    in-out property <int> selected-index: 0;
    in-out property <int> saved-selected-index: 0;
    in-out property <int> active-tab: 0;
    in-out property <int> active-group-index: 0;

    callback request-hide-window();
    callback request-select-history-item(int);
    callback request-save-history-item(int);
    callback request-move-to-front(int);
    callback request-bulk-paste-concat(int);
    callback request-bulk-paste-tab(int);
    callback request-bulk-paste-newline(int);
    callback request-select-saved-item(int);
    callback request-delete-saved-item(int);
    callback request-edit-saved-item(int);
    callback request-switch-group(int);

    // 右クリックメニュー用の状態
    property <int> ctx-target-index: -1;
    property <bool> ctx-visible: false;
    property <int> ctx-selected: 0;

    // 保存タブ右クリックメニュー用の状態
    property <int> saved-ctx-target-index: -1;
    property <bool> saved-ctx-visible: false;
    property <int> saved-ctx-selected: 0;

    property <length> row-height: 34px;
    property <length> saved-row-height: 52px;

    forward-focus: key-handler;

    key-handler := FocusScope {
        key-pressed(event) => {
            // ── コンテキストメニューが開いているときの操作 ──
            if root.ctx-visible {
                if event.text == Key.UpArrow || event.text == "k" {
                    if root.ctx-selected > 0 {
                        root.ctx-selected -= 1;
                    }
                    return accept;
                }
                if event.text == Key.DownArrow || event.text == "j" {
                    if root.ctx-selected < 4 {
                        root.ctx-selected += 1;
                    }
                    return accept;
                }
                if event.text == Key.Return {
                    if root.ctx-selected == 0 { root.request-save-history-item(root.ctx-target-index); }
                    if root.ctx-selected == 1 { root.request-move-to-front(root.ctx-target-index); }
                    if root.ctx-selected == 2 { root.request-bulk-paste-concat(root.ctx-target-index); }
                    if root.ctx-selected == 3 { root.request-bulk-paste-tab(root.ctx-target-index); }
                    if root.ctx-selected == 4 { root.request-bulk-paste-newline(root.ctx-target-index); }
                    root.ctx-visible = false;
                    return accept;
                }
                if event.text == Key.Escape || event.text == " " {
                    root.ctx-visible = false;
                    return accept;
                }
                return accept;
            }
            if root.saved-ctx-visible {
                if event.text == Key.UpArrow || event.text == "k" {
                    if root.saved-ctx-selected > 0 {
                        root.saved-ctx-selected -= 1;
                    }
                    return accept;
                }
                if event.text == Key.DownArrow || event.text == "j" {
                    if root.saved-ctx-selected < 1 {
                        root.saved-ctx-selected += 1;
                    }
                    return accept;
                }
                if event.text == Key.Return {
                    if root.saved-ctx-selected == 0 { root.request-edit-saved-item(root.saved-ctx-target-index); }
                    if root.saved-ctx-selected == 1 { root.request-delete-saved-item(root.saved-ctx-target-index); }
                    root.saved-ctx-visible = false;
                    return accept;
                }
                if event.text == Key.Escape || event.text == " " {
                    root.saved-ctx-visible = false;
                    return accept;
                }
                return accept;
            }

            // Esc で履歴ウィンドウを非表示
            if event.text == Key.Escape {
                root.request-hide-window();
                return accept;
            }

            // ── 左右キー / h,l でタブ切り替え ──
            if event.text == Key.LeftArrow || event.text == "h" {
                if root.active-tab > 0 {
                    root.active-tab -= 1;
                }
                return accept;
            }
            if event.text == Key.RightArrow || event.text == "l" {
                if root.active-tab < 1 {
                    root.active-tab += 1;
                }
                return accept;
            }

            if root.active-tab == 0 {
                if event.text == Key.UpArrow || event.text == "k" {
                    if root.selected-index > 0 {
                        root.selected-index -= 1;
                        if root.selected-index * root.row-height < history-scroll.viewport-y * -1 {
                            history-scroll.viewport-y = -1 * root.selected-index * root.row-height;
                        }
                    }
                    return accept;
                }
                if event.text == Key.DownArrow || event.text == "j" {
                    if root.selected-index < root.history-items.length - 1 {
                        root.selected-index += 1;
                        if (root.selected-index + 1) * root.row-height > history-scroll.viewport-y * -1 + history-scroll.visible-height {
                            history-scroll.viewport-y = -1 * ((root.selected-index + 1) * root.row-height - history-scroll.visible-height);
                        }
                    }
                    return accept;
                }
                if event.text == Key.Return {
                    if root.history-items.length > 0 {
                        root.request-select-history-item(root.selected-index);
                    }
                    return accept;
                }
                // Space でコンテキストメニューを開く
                if event.text == " " {
                    if root.history-items.length > 0 {
                        root.ctx-target-index = root.selected-index;
                        root.ctx-selected = 0;
                        root.ctx-visible = true;
                    }
                    return accept;
                }
            }
            if root.active-tab == 1 {
                if event.text == Key.UpArrow || event.text == "k" {
                    if root.saved-selected-index > 0 {
                        root.saved-selected-index -= 1;
                        if root.saved-selected-index * root.saved-row-height < saved-scroll.viewport-y * -1 {
                            saved-scroll.viewport-y = -1 * root.saved-selected-index * root.saved-row-height;
                        }
                    }
                    return accept;
                }
                if event.text == Key.DownArrow || event.text == "j" {
                    if root.saved-selected-index < root.saved-items.length - 1 {
                        root.saved-selected-index += 1;
                        if (root.saved-selected-index + 1) * root.saved-row-height > saved-scroll.viewport-y * -1 + saved-scroll.visible-height {
                            saved-scroll.viewport-y = -1 * ((root.saved-selected-index + 1) * root.saved-row-height - saved-scroll.visible-height);
                        }
                    }
                    return accept;
                }
                if event.text == Key.Return {
                    if root.saved-items.length > 0 {
                        root.request-select-saved-item(root.saved-selected-index);
                    }
                    return accept;
                }
                // Space でコンテキストメニューを開く
                if event.text == " " {
                    if root.saved-items.length > 0 {
                        root.saved-ctx-target-index = root.saved-selected-index;
                        root.saved-ctx-selected = 0;
                        root.saved-ctx-visible = true;
                    }
                    return accept;
                }
            }
            reject
        }

        TabWidget {
            current-index <=> root.active-tab;

            Tab {
                title: "履歴";

                history-scroll := ScrollView {
                    VerticalLayout {
                        spacing: 4px;
                        padding: 8px;

                        for item[index] in root.history-items: Rectangle {
                            min-height: 30px;
                            border-radius: 4px;
                            background: hist-touch.pressed ? #b3cfff
                                      : index == root.selected-index ? #cfe1ff
                                      : hist-touch.has-hover ? #e0e0e0
                                      : #f4f4f4;

                            Text {
                                x: 8px;
                                y: 6px;
                                width: parent.width - 16px;
                                text: "\{index + 1}. \{item}";
                                color: #111111;
                                wrap: word-wrap;
                            }

                            hist-touch := TouchArea {
                                clicked => {
                                    root.selected-index = index;
                                    root.request-select-history-item(index);
                                }
                                pointer-event(event) => {
                                    if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                                        root.ctx-target-index = index;
                                        root.ctx-selected = 0;
                                        root.ctx-visible = true;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Tab {
                title: "保存済み";

                VerticalLayout {
                    spacing: 0px;

                    // グループ切替バー
                    HorizontalLayout {
                        spacing: 6px;
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-top: 6px;
                        padding-bottom: 4px;
                        height: 34px;

                        Text {
                            text: "グループ:";
                            font-size: 13px;
                            vertical-alignment: center;
                            width: 60px;
                        }

                        ComboBox {
                            horizontal-stretch: 1;
                            model: root.group-names;
                            current-index <=> root.active-group-index;
                            selected(value) => {
                                root.request-switch-group(root.active-group-index);
                            }
                        }
                    }

                    saved-scroll := ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 4px;
                            padding: 8px;

                            if root.saved-items.length == 0: Text {
                                text: "保存されたアイテムはありません。\n履歴タブでアイテムを右クリック →「保存」で追加できます。";
                                color: #888888;
                                wrap: word-wrap;
                            }

                            for entry[index] in root.saved-items: Rectangle {
                                min-height: 48px;
                                border-radius: 4px;
                                background: saved-touch.pressed ? #b3cfff
                                          : index == root.saved-selected-index ? #cfe1ff
                                          : saved-touch.has-hover ? #e0e0e0
                                          : #f4f4f4;

                                saved-touch := TouchArea {
                                    clicked => {
                                        root.saved-selected-index = index;
                                        root.request-select-saved-item(index);
                                    }
                                    pointer-event(event) => {
                                        if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                                            root.saved-ctx-target-index = index;
                                            root.saved-ctx-selected = 0;
                                            root.saved-ctx-visible = true;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    x: 8px;
                                    y: 4px;
                                    width: parent.width - 44px;
                                    spacing: 2px;

                                    Text {
                                        text: "\{index + 1}. \{entry.title}";
                                        color: #111111;
                                        font-weight: 600;
                                        font-size: 13px;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: entry.content;
                                        color: #666666;
                                        font-size: 11px;
                                        overflow: elide;
                                    }
                                }

                                Rectangle {
                                    x: parent.width - 32px;
                                    y: 12px;
                                    width: 24px;
                                    height: 24px;
                                    border-radius: 4px;
                                    background: del-touch.has-hover ? #ffcccc : transparent;

                                    del-touch := TouchArea {
                                        clicked => {
                                            root.request-delete-saved-item(index);
                                        }
                                    }

                                    Text {
                                        text: "✕";
                                        color: #cc3333;
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── 履歴コンテキストメニュー（オーバーレイ） ──
    if root.ctx-visible: Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: #00000040;

        // 背景クリックで閉じる
        TouchArea {
            clicked => {
                root.ctx-visible = false;
            }
        }

        Rectangle {
            x: (root.width - 280px) / 2;
            y: (root.height - 200px) / 2;
            width: 280px;
            height: 200px;
            background: white;
            border-width: 1px;
            border-color: #999999;
            border-radius: 6px;
            clip: true;

            VerticalLayout {
                spacing: 0px;
                padding: 4px;

                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: root.ctx-selected == 0 ? #cfe1ff
                              : ctx-save-touch.has-hover ? #e8e8e8 : transparent;

                    ctx-save-touch := TouchArea {
                        clicked => {
                            root.request-save-history-item(root.ctx-target-index);
                            root.ctx-visible = false;
                        }
                        moved => {
                            root.ctx-selected = 0;
                        }
                    }

                    Text {
                        text: "📌 保存";
                        x: 10px;
                        color: #111111;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: root.ctx-selected == 1 ? #cfe1ff
                              : ctx-front-touch.has-hover ? #e8e8e8 : transparent;

                    ctx-front-touch := TouchArea {
                        clicked => {
                            root.request-move-to-front(root.ctx-target-index);
                            root.ctx-visible = false;
                        }
                        moved => {
                            root.ctx-selected = 1;
                        }
                    }

                    Text {
                        text: "⏫ 最新に移動";
                        x: 10px;
                        color: #111111;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 1px;
                    background: #dddddd;
                }

                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: root.ctx-selected == 2 ? #cfe1ff
                              : ctx-concat-touch.has-hover ? #e8e8e8 : transparent;

                    ctx-concat-touch := TouchArea {
                        clicked => {
                            root.request-bulk-paste-concat(root.ctx-target-index);
                            root.ctx-visible = false;
                        }
                        moved => {
                            root.ctx-selected = 2;
                        }
                    }

                    Text {
                        text: "📋 この行以上を一括貼付(連結)";
                        x: 10px;
                        color: #111111;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: root.ctx-selected == 3 ? #cfe1ff
                              : ctx-tab-touch.has-hover ? #e8e8e8 : transparent;

                    ctx-tab-touch := TouchArea {
                        clicked => {
                            root.request-bulk-paste-tab(root.ctx-target-index);
                            root.ctx-visible = false;
                        }
                        moved => {
                            root.ctx-selected = 3;
                        }
                    }

                    Text {
                        text: "📋 この行以上を一括貼付(Tab)";
                        x: 10px;
                        color: #111111;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: root.ctx-selected == 4 ? #cfe1ff
                              : ctx-nl-touch.has-hover ? #e8e8e8 : transparent;

                    ctx-nl-touch := TouchArea {
                        clicked => {
                            root.request-bulk-paste-newline(root.ctx-target-index);
                            root.ctx-visible = false;
                        }
                        moved => {
                            root.ctx-selected = 4;
                        }
                    }

                    Text {
                        text: "📋 この行以上を一括貼付(改行)";
                        x: 10px;
                        color: #111111;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // ── 保存タブコンテキストメニュー（オーバーレイ） ──
    if root.saved-ctx-visible: Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        background: #00000040;

        TouchArea {
            clicked => {
                root.saved-ctx-visible = false;
            }
        }

        Rectangle {
            x: (root.width - 180px) / 2;
            y: (root.height - 80px) / 2;
            width: 180px;
            height: 80px;
            background: white;
            border-width: 1px;
            border-color: #999999;
            border-radius: 6px;
            clip: true;

            VerticalLayout {
                spacing: 0px;
                padding: 4px;

                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: root.saved-ctx-selected == 0 ? #cfe1ff
                              : saved-edit-touch.has-hover ? #e8e8e8 : transparent;

                    saved-edit-touch := TouchArea {
                        clicked => {
                            root.request-edit-saved-item(root.saved-ctx-target-index);
                            root.saved-ctx-visible = false;
                        }
                        moved => {
                            root.saved-ctx-selected = 0;
                        }
                    }

                    Text {
                        text: "✏️ 編集";
                        x: 10px;
                        color: #111111;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: root.saved-ctx-selected == 1 ? #cfe1ff
                              : saved-del-touch.has-hover ? #ffe0e0 : transparent;

                    saved-del-touch := TouchArea {
                        clicked => {
                            root.request-delete-saved-item(root.saved-ctx-target-index);
                            root.saved-ctx-visible = false;
                        }
                        moved => {
                            root.saved-ctx-selected = 1;
                        }
                    }

                    Text {
                        text: "✕ 削除";
                        x: 10px;
                        color: #cc3333;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

export component SaveDialogWindow inherits Window {
    title: "アイテム保存";
    width: 500px;
    height: 440px;

    in-out property <string> save-title: "";
    in-out property <string> save-content: "";
    in property <[string]> group-names;
    in-out property <int> selected-group-index: 0;
    in-out property <bool> creating-new-group: false;
    in-out property <string> new-group-name: "";

    callback request-confirm-save(string, string, string);
    callback request-cancel-save();

    VerticalBox {
        spacing: 8px;
        padding: 12px;

        Text {
            text: "アイテムを保存";
            font-size: 20px;
            font-weight: 700;
        }

        Text { text: "グループ"; font-weight: 600; }
        HorizontalLayout {
            spacing: 6px;
            height: 30px;

            ComboBox {
                horizontal-stretch: 1;
                model: root.group-names;
                current-index <=> root.selected-group-index;
                enabled: !root.creating-new-group;
            }

            Button {
                text: root.creating-new-group ? "既存" : "+ 新規";
                clicked => {
                    root.creating-new-group = !root.creating-new-group;
                    root.new-group-name = "";
                }
            }
        }

        if root.creating-new-group: HorizontalLayout {
            spacing: 6px;
            height: 30px;

            Text {
                text: "新しいグループ名:";
                font-size: 13px;
                vertical-alignment: center;
                width: 120px;
            }

            LineEdit {
                horizontal-stretch: 1;
                text <=> root.new-group-name;
            }
        }

        Text { text: "タイトル"; font-weight: 600; }
        LineEdit {
            text <=> root.save-title;
        }

        Text { text: "内容"; font-weight: 600; }
        TextEdit {
            text <=> root.save-content;
            vertical-stretch: 1;
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: end;

            Button {
                text: "キャンセル";
                clicked => {
                    root.request-cancel-save();
                }
            }

            Button {
                text: "保存";
                clicked => {
                    if root.creating-new-group && root.new-group-name != "" {
                        root.request-confirm-save(root.new-group-name, root.save-title, root.save-content);
                    } else if root.group-names.length > 0 {
                        root.request-confirm-save(root.group-names[root.selected-group-index], root.save-title, root.save-content);
                    }
                }
            }
        }
    }
}

export component EditSavedDialogWindow inherits Window {
    title: "アイテム編集";
    width: 500px;
    height: 400px;

    in-out property <string> edit-title: "";
    in-out property <string> edit-content: "";
    in-out property <int> edit-index: -1;

    callback request-confirm-edit(int, string, string);
    callback request-cancel-edit();

    VerticalBox {
        spacing: 8px;
        padding: 12px;

        Text {
            text: "アイテムを編集";
            font-size: 20px;
            font-weight: 700;
        }

        Text { text: "タイトル"; font-weight: 600; }
        LineEdit {
            text <=> root.edit-title;
        }

        Text { text: "内容"; font-weight: 600; }
        TextEdit {
            text <=> root.edit-content;
            vertical-stretch: 1;
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: end;

            Button {
                text: "キャンセル";
                clicked => {
                    root.request-cancel-edit();
                }
            }

            Button {
                text: "保存";
                clicked => {
                    root.request-confirm-edit(root.edit-index, root.edit-title, root.edit-content);
                }
            }
        }
    }
}

export component SettingsWindow inherits Window {
    title: "クリップキーパー設定";
    width: 460px;
    height: 360px;

    in-out property <int> hotkey-mode: 0;
    in-out property <bool> hotkey-combo-ctrl-required: true;
    in-out property <bool> hotkey-combo-shift-required: false;
    in-out property <string> hotkey-combo-key: "H";

    callback request-set-hotkey-mode(int);
    callback request-set-hotkey-combo-ctrl-required(bool);
    callback request-set-hotkey-combo-shift-required(bool);
    callback request-set-hotkey-combo-key(string);

    VerticalBox {
        spacing: 8px;
        padding: 12px;

        Text {
            text: "設定";
            font-size: 22px;
            font-weight: 700;
        }

        Text {
            text: "ホットキー設定";
            font-size: 16px;
            font-weight: 600;
        }

        Text {
            text: "履歴ウィンドウの呼び出し方法";
        }

        ComboBox {
            model: ["Shift 2回押し", "Ctrl 2回押し", "修飾キー + ホットキー"];
            current-index <=> root.hotkey-mode;
            selected(value) => {
                root.request-set-hotkey-mode(root.hotkey-mode);
            }
        }

        if root.hotkey-mode == 2 : VerticalLayout {
            spacing: 4px;
            padding-top: 4px;

            CheckBox {
                text: "Ctrlを必須にする";
                checked <=> root.hotkey-combo-ctrl-required;
                toggled => {
                    root.request-set-hotkey-combo-ctrl-required(self.checked);
                }
            }

            CheckBox {
                text: "Shiftを必須にする";
                checked <=> root.hotkey-combo-shift-required;
                toggled => {
                    root.request-set-hotkey-combo-shift-required(self.checked);
                }
            }

            Text {
                text: "ホットキー（A-Z / 0-9、初期値 H）";
            }

            LineEdit {
                text <=> root.hotkey-combo-key;
                edited(new-value) => {
                    root.request-set-hotkey-combo-key(new-value);
                }
            }
        }

        Text {
            wrap: word-wrap;
            text: "変更はすぐに settings.json に保存されます。";
        }
    }
}
